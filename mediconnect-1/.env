# Leave CLIENT_SECRET empty for public client (patient-facing apps)
CLIENT_SECRET=

# JWT Key for Backend Services (if using server-to-server)
JWT_SIGNING_KEY=C0A32FAE613E587E1470040CA47A51CD23489073

# Redirect URI (must match Epic registration)
REDIRECT_URI=https://localhost:8000/callback

# Patient Portal Authorization URL (Epic MyChart sandbox endpoint)
PATIENT_AUTHORIZATION_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize

# Session & JWT Secrets
SESSION_SECRET_KEY=drkcXZX2R5Xq8dkkqvvx4LvDqe8XoRkaSTnDZxmRjew
JWT_SECRET_KEY=tm3Dry8yk97+6ktSB2Op+P02dpVQF2RyXWFuYGnBxWg=

# Application Settings
APP_NAME=MediConnect
APP_VERSION=1.0.0

# Frontend Origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000,https://127.0.0.1:3000

# Note: Epic often requires redirect URIs to use HTTPS. We run the backend at https://localhost:8000 for OAuth callbacks.

# FHIR Scopes - Update if needed
