# ===========================================
# REQUIRED Environment Variables for Production
# ===========================================

# MongoDB Connection
MONGO_URI=your_mongodb_connection_string_here

# Encryption Key (Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
AES_KEY=your_base64_encoded_32_byte_key_here

# JWT Secret (Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
JWT_SECRET_KEY=your_jwt_secret_key_here

# Session Secret (Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
SESSION_SECRET_KEY=your_session_secret_key_here

# ===========================================
# FHIR/Epic Integration (Sandbox)
# ===========================================
FHIR_SERVER_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
CLIENT_ID=your_epic_client_id_here
CLIENT_SECRET=your_epic_client_secret_here

# IMPORTANT: Update this with your Vercel deployment URL
REDIRECT_URI=https://your-app.vercel.app/api/callback

# FHIR Scopes
FHIR_SCOPES=patient/Patient.r patient/AllergyIntolerance.r patient/Condition.r patient/Observation.r patient/MedicationRequest.r patient/Immunization.r patient/DocumentReference.r launch/patient openid fhirUser

# ===========================================
# CORS Configuration
# ===========================================
# IMPORTANT: Update this with your Vercel deployment URL
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ===========================================
# Application Configuration
# ===========================================
APP_NAME=MediConnect
APP_VERSION=1.0.0
DEBUG=False
